<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ExpenseTrackerApp.Views.HomePage">

    <VerticalStackLayout Padding="20">
        <Label Text="Expense Tracker" FontSize="24"/>

        <Label Text="{Binding TotalExpenses}" />
        <Label Text="{Binding TotalAmount}" />

        <Button Text="Categories" Clicked="GoCategories"/>
        <Button Text="Expenses" Clicked="GoExpenses"/>
    </VerticalStackLayout>

</ContentPage>