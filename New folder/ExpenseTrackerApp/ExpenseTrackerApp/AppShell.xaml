<Shell
    x:Class="ExpenseTrackerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ExpenseTrackerApp.Views">

    <!-- Home Page -->
    <ShellContent 
        Title="Home"
        ContentTemplate="{DataTemplate views:HomePage}" />

    <!-- Categories Page -->
    <ShellContent 
        Title="Categories"
        ContentTemplate="{DataTemplate views:CategoryPage}" />

    <!-- Expenses Page -->
    <ShellContent 
        Title="Expenses"
        ContentTemplate="{DataTemplate views:ExpensePage}" />

</Shell>