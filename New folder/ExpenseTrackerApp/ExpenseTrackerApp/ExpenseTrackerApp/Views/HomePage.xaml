<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ExpenseTrackerApp.Views.HomePage">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="💰 Expense Tracker"
               FontSize="28"
               HorizontalOptions="Center" />

        <Label Text="{Binding TotalExpenses}"
               FontSize="20"
               TextColor="Black" />

        <Label Text="{Binding TotalAmount}"
               FontSize="20"
               TextColor="Black" />

    </VerticalStackLayout>

</ContentPage>