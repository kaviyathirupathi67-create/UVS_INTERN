<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SkillUp.Platform.Views.MainPage">

    <VerticalStackLayout Padding="20">

        <Entry Placeholder="Your Name" Text="{Binding Name}" />
        <Entry Placeholder="Skill You Offer" Text="{Binding SkillOffered}" />
        <Entry Placeholder="Skill You Want" Text="{Binding SkillWanted}" />

        <Button Text="Add Skill" Command="{Binding AddSkillCommand}" />

        <CollectionView ItemsSource="{Binding Skills}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontAttributes="Bold"/>
                            <Label Text="{Binding SkillOffered}" />
                            <Label Text="{Binding SkillWanted}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>