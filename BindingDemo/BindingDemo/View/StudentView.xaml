<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BindingDemo.View.StudentView"
             Title="StudentView">
    <VerticalStackLayout Spacing="10" VerticalOptions="Center">
        <Entry Placeholder="First name" Text="{Binding FirstName}" />
        <Entry Placeholder="Last name" Text="{Binding LastName}" />

        <Label Text="{Binding FullName}" FontSize="20" TextColor="White" />

        <Button Text="Generate name" Command="{Binding GenerateNameCommand}" />
    </VerticalStackLayout>
</ContentPage>